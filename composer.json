{
  "name": "iriven/php-form-generator",
  "description": "Enterprise form framework for PHP with nested forms, collections, transformers, events and themes",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "symfony/event-dispatcher": "^7.4",
    "symfony/options-resolver": "^7.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "infection/infection": "^0.29",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.5",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    },
    "files": [
      "src/legacy_aliases.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=never",
    "test:coverage": "vendor/bin/phpunit --coverage-text",
    "analyse": "vendor/bin/phpstan analyse src tests",
    "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs:fix": "vendor/bin/php-cs-fixer fix",
    "refactor": "vendor/bin/rector process",
    "mutate": "vendor/bin/infection --threads=max --min-msi=70 --min-covered-msi=80"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
