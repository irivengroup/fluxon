{
  "name": "iriven/php-form-generator",
  "description": "Enterprise-oriented PHP form framework starter with fieldsets, validation, CSRF, events, themes and mappers.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.0",
    "rector/rector": "^1.1",
    "infection/infection": "^0.29"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always",
    "analyse": "phpstan analyse src tests",
    "fix": "php-cs-fixer fix --allow-risky=yes",
    "mutate": "infection --threads=max"
  }
}
