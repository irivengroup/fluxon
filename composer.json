{
  "name": "iriven/php-form-generator",
  "description": "Enterprise form framework starter with validation, mapping, CSRF, nested forms, events and HTML rendering.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "php -l $(find src -name '*.php')"
  }
}
