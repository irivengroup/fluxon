{
  "name": "iriven/php-form-generator",
  "description": "Enterprise form framework for PHP with nested forms, collections, transformers, events and themes",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "infection/infection": "^0.29",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.5",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=never",
    "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --colors=never --coverage-clover=coverage.clover --coverage-text",
    "analyse": "vendor/bin/phpstan analyse src tests",
    "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs:fix": "vendor/bin/php-cs-fixer fix",
    "refactor": "vendor/bin/rector process",
    "mutate": "vendor/bin/infection --threads=max --min-msi=70 --min-covered-msi=80",
    "qa": [
      "@phpstan analyse src tests",
      "@phpunit --colors=never"
    ],
    "release:check": [
      "composer dump-autoload -o",
      "@phpstan analyse src tests",
      "@phpunit --colors=never"
    ],
    "validate:full": [
      "composer dump-autoload -o",
      "@phpstan analyse src tests",
      "@phpunit --colors=never"
    ],
    "rc:check": [
      "@validate:full"
    ],
    "maintenance:check": [
      "composer dump-autoload -o",
      "@phpstan analyse src tests",
      "@phpunit --colors=never"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "release_name": "V5.0.0 API publique figée et industrialisation finale",
    "release_channel": "major-stable"
  }
}
